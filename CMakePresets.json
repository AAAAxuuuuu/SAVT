{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "qt-mingw-debug",
      "displayName": "Qt Creator / Qt 6.9.3 MinGW Debug",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/qtcreator-qt6.9.3-mingw-debug",
      "environment": {
        "PATH": "F:/Qt/Tools/mingw1310_64/bin;F:/Qt/6.9.3/mingw_64/bin;$penv{PATH}"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "F:/Qt/Tools/mingw1310_64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "F:/Qt/Tools/mingw1310_64/bin/g++.exe",
        "CMAKE_MAKE_PROGRAM": "F:/Qt/Tools/mingw1310_64/bin/mingw32-make.exe",
        "CMAKE_PREFIX_PATH": "F:/Qt/6.9.3/mingw_64"
      }
    },
    {
      "name": "qt-mingw-release",
      "displayName": "Qt Creator / Qt 6.9.3 MinGW Release",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/qtcreator-qt6.9.3-mingw-release",
      "environment": {
        "PATH": "F:/Qt/Tools/mingw1310_64/bin;F:/Qt/6.9.3/mingw_64/bin;$penv{PATH}"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "F:/Qt/Tools/mingw1310_64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "F:/Qt/Tools/mingw1310_64/bin/g++.exe",
        "CMAKE_MAKE_PROGRAM": "F:/Qt/Tools/mingw1310_64/bin/mingw32-make.exe",
        "CMAKE_PREFIX_PATH": "F:/Qt/6.9.3/mingw_64"
      }
    },
    {
      "name": "qt-msvc2022-debug",
      "displayName": "Qt Creator / Qt 6.9.3 MSVC2022 Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/qtcreator-qt6.9.3-msvc2022_64-debug",
      "environment": {
        "PATH": "${sourceDir}/tools/llvm/clang+llvm-21.1.7-x86_64-pc-windows-msvc/bin;F:/Qt/Tools/Ninja;$penv{PATH}"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "F:/QT/6.9.3/msvc2022_64",
        "CMAKE_MAKE_PROGRAM": "F:/Qt/Tools/Ninja/ninja.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "SAVT_ENABLE_CLANG_TOOLING": "ON",
        "SAVT_LLVM_ROOT": "${sourceDir}/tools/llvm/clang+llvm-21.1.7-x86_64-pc-windows-msvc"
      }
    },
    {
      "name": "qt-msvc2022-release",
      "displayName": "Qt Creator / Qt 6.9.3 MSVC2022 Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/qtcreator-qt6.9.3-msvc2022_64-release",
      "environment": {
        "PATH": "${sourceDir}/tools/llvm/clang+llvm-21.1.7-x86_64-pc-windows-msvc/bin;F:/Qt/Tools/Ninja;$penv{PATH}"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_PREFIX_PATH": "F:/QT/6.9.3/msvc2022_64",
        "CMAKE_MAKE_PROGRAM": "F:/Qt/Tools/Ninja/ninja.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "SAVT_ENABLE_CLANG_TOOLING": "ON",
        "SAVT_LLVM_ROOT": "${sourceDir}/tools/llvm/clang+llvm-21.1.7-x86_64-pc-windows-msvc"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "qt-mingw-debug",
      "configurePreset": "qt-mingw-debug"
    },
    {
      "name": "qt-mingw-release",
      "configurePreset": "qt-mingw-release"
    },
    {
      "name": "qt-msvc2022-debug",
      "configurePreset": "qt-msvc2022-debug"
    },
    {
      "name": "qt-msvc2022-release",
      "configurePreset": "qt-msvc2022-release"
    }
  ]
