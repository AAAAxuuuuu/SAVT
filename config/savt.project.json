{
    "analysis": {
        "dependencyFoldRules": [
            {
                "collapse": true,
                "hideByDefault": true,
                "match": "third_party"
            }
        ],
        "entryOverrides": [
            {
                "entry": true,
                "match": "apps/desktop"
            },
            {
                "entry": true,
                "match": "apps/desktop/qml"
            }
        ],
        "ignoreDirectories": [
            ".git",
            ".vscode",
            "build",
            "docs",
            "samples",
            "tests"
        ],
        "moduleMerges": [
            {
                "match": "src/ai/include",
                "module": "src/ai"
            },
            {
                "match": "src/ai/src",
                "module": "src/ai"
            },
            {
                "match": "src/analyzer/include",
                "module": "src/analyzer"
            },
            {
                "match": "src/analyzer/src",
                "module": "src/analyzer"
            },
            {
                "match": "src/core/include",
                "module": "src/core"
            },
            {
                "match": "src/core/src",
                "module": "src/core"
            },
            {
                "match": "src/layout/include",
                "module": "src/layout"
            },
            {
                "match": "src/layout/src",
                "module": "src/layout"
            },
            {
                "match": "src/parser/include",
                "module": "src/parser"
            },
            {
                "match": "src/parser/src",
                "module": "src/parser"
            },
            {
                "match": "src/ui/include",
                "module": "src/ui"
            },
            {
                "match": "src/ui/src",
                "module": "src/ui"
            }
        ],
        "roleOverrides": [
            {
                "match": "apps/desktop/qml",
                "role": "presentation"
            }
        ]
    },
    "version": 1
}
